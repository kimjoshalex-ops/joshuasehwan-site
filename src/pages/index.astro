---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Joshua Sehwan Kim">
  <main class="container">

    <img src="/ENTANGLEMENT-COVER.jpeg" alt="Entanglement cover" class="headshot" />

    <h1>Entanglement</h1>

    <p class="tagline">
      2026 – A new graphic novel with Ciara Ni Chuirc
    </p>

    <p>
      Welcome to my official website.
    </p>

  </main>
</Layout>

<style>
  .container {
    max-width: 700px;
    margin: 60px auto;
    padding: 20px;
    text-align: center;
  }

  .headshot {
    width: 250px;
    max-width: 100%;
    border-radius: 8px;
  }

  h1 {
    font-size: 2.8rem;
    margin-top: 30px;
  }

  .tagline,
  p {
    line-height: 1.7;
    font-size: 1.1rem;
  }
</style>