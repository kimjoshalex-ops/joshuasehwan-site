---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Joshua Sehwan Kim">
  <main class="container">

    <p class="name">Joshua Sehwan Kim</p>

    <p class="contact">for all inquiries, please email jkim.sehw@gmail.com</p>

    <p class="break">----</p>

    <p class="date">2025.08.27</p>

    <p class="words">"Entanglement" - a graphic novel</p>

    <img src="/ENTANGLEMENT-COVER.jpeg" alt="Entanglement cover" class="cover" />

  </main>
</Layout>

<style>
  .container {
    max-width: 720px;
    margin: 80px auto;
    padding: 24px;
    text-align: center;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .cover {
    width: 260px;
    max-width: 100%;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  }

  p {
    margin-bottom: 16px;
  }

  .name {
    font-size: 1.2rem;
    letter-spacing: 0.05em;
  }

  .contact {
    font-size: 0.95rem;
    opacity: 0.7;
  }

  .break {
    opacity: 0.4;
    letter-spacing: 0.2em;
  }

  .date {
    font-size: 0.95rem;
    opacity: 0.6;
    letter-spacing: 0.08em;
  }

  .words {
    font-size: 1.1rem;
  }
</style>